{
  "manifest_version": 3,
  "name": "Scipio Auto-Apply",
  "version": "1.6.1",
  "description": "Auto-fill job applications with your profile. Works on any site.",
  "permissions": ["activeTab", "storage", "scripting", "clipboardRead", "clipboardWrite"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
